<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Force HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 2. Force non-WWW (redirect www to root)
  RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

  # 3. Redirect /charles to /familia
  RewriteRule ^charles$ /familia [R=301,L]

  # 4. SPA Routing
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Authorized: Self, Google Fonts, Voiceflow, DolarAPI
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.voiceflow.com blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.voiceflow.com; font-src 'self' https://fonts.gstatic.com https://cdn.voiceflow.com; connect-src 'self' https://general-runtime.voiceflow.com https://cdn.voiceflow.com https://ve.dolarapi.com https://runtime-api.voiceflow.com wss://general-runtime.voiceflow.com; img-src 'self' data: https://cdn.voiceflow.com https://*.voiceflow.com https://*.vf-assets.com https://cm4-production-assets.s3.amazonaws.com; frame-src 'self' https://*.voiceflow.com https://*.voiceflow.io; object-src 'none'; base-uri 'self'; upgrade-insecure-requests;"
    
  # Security Hardening
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>
